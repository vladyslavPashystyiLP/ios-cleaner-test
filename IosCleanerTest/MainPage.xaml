<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IosCleanerTest.MainPage"
             Title="Cleaner Test">

    <ContentPage.Resources>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Stroke" Value="LightGray" />
            <Setter Property="StrokeShape" Value="RoundRectangle 10" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style x:Key="CategoryTitle" TargetType="Label">
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="16" />
        </Style>
        <Style x:Key="ResultLabel" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextColor" Value="Gray" />
            <Setter Property="LineBreakMode" Value="WordWrap" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="12">

            <Label Text="Рівень 1 — пошук за метаданими"
                   FontSize="20" FontAttributes="Bold" />

            <Label x:Name="AccessStatusLabel" Text="Доступ до галереї: не запитано"
                   Style="{StaticResource ResultLabel}" />

            <Border Style="{StaticResource SectionBorder}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Скриншоти" Style="{StaticResource CategoryTitle}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Сканувати" Clicked="OnScanScreenshots" />
                        <Button Text="Додати тестові" Clicked="OnSeedScreenshot" />
                    </HorizontalStackLayout>
                    <Label x:Name="ScreenshotsResult" Style="{StaticResource ResultLabel}" Text="—" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Live Photos" Style="{StaticResource CategoryTitle}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Сканувати" Clicked="OnScanLivePhotos" />
                        <Button Text="Додати тестові" Clicked="OnSeedLivePhoto" />
                    </HorizontalStackLayout>
                    <Label x:Name="LivePhotosResult" Style="{StaticResource ResultLabel}" Text="—" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Великі відео (від 10 МБ)" Style="{StaticResource CategoryTitle}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Сканувати" Clicked="OnScanLargeVideos" />
                        <Button Text="Додати тестові" Clicked="OnSeedLargeVideo" />
                    </HorizontalStackLayout>
                    <Label x:Name="LargeVideosResult" Style="{StaticResource ResultLabel}" Text="—" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource SectionBorder}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Найважчі файли (топ-10)" Style="{StaticResource CategoryTitle}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="Сканувати" Clicked="OnScanHeaviest" />
                        <Button Text="Додати тестові" Clicked="OnSeedHeavyImages" />
                    </HorizontalStackLayout>
                    <Label x:Name="HeaviestResult" Style="{StaticResource ResultLabel}" Text="—" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
